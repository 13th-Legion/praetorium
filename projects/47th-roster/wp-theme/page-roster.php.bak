  max-width: 400px;
  font-family: inherit;
}

.search-box input::placeholder {
  color: #888;
}

.roster-container {
  max-width: 1600px;
  margin-left: auto;
  margin-right: auto;
  padding: 0 2rem;
}

.category-section {
  margin-bottom: 2rem;
}

.category-header {
  color: #c9a227;
  font-size: 1.5rem;
  border-bottom: 2px solid #c9a227;
