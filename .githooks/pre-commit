#!/bin/bash
# Pre-commit secret scanner for 13th-Legion/praetorium
# Blocks commits containing known credential patterns

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

PATTERNS=(
  # API tokens
  'dop_v1_[a-f0-9]{64}'
  'MTQ[A-Za-z0-9_.-]{50,}'
  'AexIbJH[A-Za-z0-9_-]{30,}'
  'SDIfR7[A-Za-z0-9_-]{30,}'
  '23LGvax[A-Za-z0-9_-]{30,}'

  # Known passwords
  'Gh0st.nTh3Mach1n3'
  'sUp3rS3cr3tDBP4ssw0rd'
  'Pr43t0r.umDB'
  'Pr43t0r.Nc[0-9]+'
  'Pr43t0r.umSvc'
  'p9Gy.*slQZlb'
  'Wk4tYn.8BfXq2Jh6'
  'Nx7cR.pLm3QvKd9s'
  'Rd5mHv.9CpTx3Lw1'
  'C0ll4b0r4.13th'
  'C0turn_13thLeg10n'
  '55CBXLln.Z'
  'JZxHNzQlDy_K_57FKc4fZA'
  'RJGH78Fkw'
  'Nez0RccDB'
  'WZWzHnVsGl'
  'c1cDVUJs'
  'xqbJdh.wQXqRc3'

  # Service tokens
  'f4bcfe7ad40cf6f2117'
  '4g-bg1vFOZJ-9j1lXI0g'
  'SAZX6PBBRP2675BM'

  # NC share tokens
  'NGDDQeWomERbW6H'
  'wo55qzEobMfw4An'
  'KB7so2iAWcHoDpJ'
  'XGG4BgFjwakmxDf'
  'yC6AzC6qfgjByna'
  'eZx9b9xRoFRw3Bt'
  'cTFEDpszLBj72R8'
  'iZZsHRr3fAsJf2j'
)

VIOLATIONS=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

[ -z "$STAGED_FILES" ] && exit 0

for file in $STAGED_FILES; do
  # Skip binaries and example files
  case "$file" in
    *.png|*.jpg|*.jpeg|*.gif|*.pdf|*.ico|*.webp|*.svg|.env.example) continue ;;
    .githooks/*) continue ;;
  esac

  content=$(git show ":$file" 2>/dev/null) || continue

  for pattern in "${PATTERNS[@]}"; do
    matches=$(echo "$content" | grep -nE "$pattern" 2>/dev/null)
    if [ -n "$matches" ]; then
      echo -e "${RED}🚨 SECRET DETECTED${NC} in ${YELLOW}$file${NC}:"
      echo "$matches" | head -3 | while read -r line; do
        echo -e "   ${RED}→${NC} $line"
      done
      VIOLATIONS=$((VIOLATIONS + 1))
    fi
  done
done

if [ $VIOLATIONS -gt 0 ]; then
  echo ""
  echo -e "${RED}═══════════════════════════════════════════════${NC}"
  echo -e "${RED} COMMIT BLOCKED: $VIOLATIONS secret pattern(s) found${NC}"
  echo -e "${RED}═══════════════════════════════════════════════${NC}"
  echo ""
  echo "Fix: move credentials to .env / environment variables."
  echo "Override (emergency only): git commit --no-verify"
  exit 1
fi

exit 0
