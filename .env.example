# Praetorium Portal — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Database
POSTGRES_DB=praetorium
POSTGRES_USER=praetorium
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://praetorium:changeme@db:5432/praetorium
DATABASE_URL_SYNC=postgresql+psycopg2://praetorium:changeme@db:5432/praetorium

# App
SECRET_KEY=CHANGE-ME

# Nextcloud OAuth (portal-svc OAuth app)
NC_URL=https://cloud.13thlegion.org
NC_CLIENT_ID=your-nc-oauth-client-id
NC_CLIENT_SECRET=your-nc-oauth-client-secret
NC_API_USER=portal-svc
NC_API_PASSWORD=changeme

# Nextcloud service accounts (used by app services)
NC_SVC_USER=spooky
NC_SVC_PASS=changeme
NC_PORTAL_SVC_USER=portal-svc
NC_PORTAL_SVC_PASS=changeme

# SMTP
SMTP_HOST=172.21.0.1
SMTP_PORT=1025
SMTP_USER=admin@13thlegion.org
SMTP_PASS=changeme
SMTP_FROM=13th Legion <admin@13thlegion.org>

# App URL
APP_URL=https://portal.13thlegion.org
DEBUG=false
